# Copy to .env and edit. .env is gitignored.

# AWS auth -- preferred path is `aws configure` / SSO + AWS_PROFILE.
# If you must use static keys, uncomment the AWS_ACCESS_KEY_ID block instead.
AWS_PROFILE=default
AWS_REGION=us-east-1

# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=

# Terragrunt-resolved Terraform vars (override env.hcl defaults if needed)
TF_VAR_cluster_name=eks-lab
