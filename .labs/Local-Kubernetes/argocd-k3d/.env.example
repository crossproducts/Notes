# Copy to .env (gitignored), then load into the cluster:
#
#   kubectl create secret generic openclaw-llm-keys -n openclaw \
#     --from-env-file=.labs/Local-Kubernetes/argocd-k3d/.env
#   kubectl annotate secret openclaw-llm-keys -n openclaw \
#     argocd.argoproj.io/sync-options=Prune=false
#
# The annotate step prevents ArgoCD's prune sweep from deleting the
# Secret because it doesn't appear in any tracked manifest.
#
# To rotate: delete the secret, recreate from updated .env, restart pod.

OPENAI_API_KEY=sk-replace-me
